{%- set ServiceName = service_name | pascal_case -%}
{%- set SourceService = source_service | pascal_case -%}
use shared::events::{EventEnvelope, EventMetadata, EventType, SourceService, AggregateType};
use uuid::Uuid;

fn make_envelope(event_type: EventType, aggregate_id: Uuid, payload: serde_json::Value) -> EventEnvelope {
    EventEnvelope {
        metadata: EventMetadata {
            event_id: Uuid::new_v4(),
            event_type,
            source_service: SourceService::{{ SourceService }},
            aggregate_type: AggregateType::Order, // <ai:customize hint="Set correct aggregate type">
            aggregate_id,
            version: 1,
            timestamp: chrono::Utc::now(),
        },
        payload,
    }
}

