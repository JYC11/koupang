{%- set EntityName = entity_name | pascal_case -%}
{%- set EntityPlural = entity_name | pluralize -%}
use {{ service_name }}::{{ EntityPlural }}::repository;

#[tokio::test]
async fn create_{{ entity_name }}_succeeds() {
    let db = crate::common::test_db().await;
    let mut conn = db.pool.acquire().await.unwrap();
