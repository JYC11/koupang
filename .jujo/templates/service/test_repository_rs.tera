// ── Get by ID ───────────────────────────────────────────────

#[tokio::test]
async fn get_{{ entity_name }}_not_found() {
    let db = crate::common::test_db().await;
    let id = {{ service_name }}::{{ EntityPlural }}::value_objects::{{ EntityName }}Id::new(uuid::Uuid::new_v4());
    let result = repository::get_{{ entity_name }}_by_id(&db.pool, id).await;
    assert!(result.is_err());
}

// ── List ────────────────────────────────────────────────────

#[tokio::test]
async fn list_{{ EntityPlural }}_empty() {
    let db = crate::common::test_db().await;
    let params = shared::db::pagination_support::PaginationParams::default();
    let filter = {{ service_name }}::{{ EntityPlural }}::dtos::{{ EntityName }}Filter {
        // <ai:customize hint="Initialize filter fields">
        // </ai:customize>
    };
    let result = repository::list_{{ EntityPlural }}(&db.pool, &params, &filter).await.unwrap();
    assert!(result.is_empty());
}

// ── Delete ──────────────────────────────────────────────────

#[tokio::test]
async fn delete_nonexistent_{{ entity_name }}_fails() {
    let db = crate::common::test_db().await;
    let mut conn = db.pool.acquire().await.unwrap();
    let id = {{ service_name }}::{{ EntityPlural }}::value_objects::{{ EntityName }}Id::new(uuid::Uuid::new_v4());
    let result = repository::delete_{{ entity_name }}(&mut *conn, id).await;
    assert!(result.is_err());
}
